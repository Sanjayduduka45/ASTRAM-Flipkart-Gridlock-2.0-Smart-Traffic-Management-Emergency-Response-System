# ASTRAM - Environment Variables Configuration Template
# Copy this file to .env and configure with your keys.

# Gemini API Credentials (for traffic insights and recommendations)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Configurations (for reports and incidents persistence)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_publishable_key_here
